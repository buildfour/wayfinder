generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String            @unique
  emailVerified    DateTime?
  passwordHash     String?
  plan             String            @default("explorer")
  image            String?
  accounts         Account[]
  sessions         Session[]
  tours            TourRecord[]
  settings         UserSettings?
  connectedSources ConnectedSource[]
  teamMembers      TeamMember[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TourRecord {
  id        String              @id
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  data      String
  progress  TourProgressRecord?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([userId])
}

model TourProgressRecord {
  id               String     @id @default(cuid())
  tourId           String     @unique
  tour             TourRecord @relation(fields: [tourId], references: [id], onDelete: Cascade)
  currentStepIndex Int        @default(0)
  completedStepIds String     @default("[]")
  selectedBranch   String?
  startTime        BigInt
  elapsedMinutes   Int        @default(0)
}

model UserSettings {
  id                 String  @id @default(cuid())
  userId             String  @unique
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  showCheckpoints    Boolean @default(true)
  autoBranchByOS     Boolean @default(false)
  showTimeEstimates  Boolean @default(true)
  notifyOnSourceChange Boolean @default(true)
}

model ConnectedSource {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  String
  label     String
  status    String   @default("pending")
  createdAt DateTime @default(now())

  @@index([userId])
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  role      String   @default("viewer")
  status    String   @default("invited")
  createdAt DateTime @default(now())

  @@index([userId])
}
