# OpenAI API key (optional legacy)
OPENAI_API_KEY=

# Google Gemini — tour extraction (gemini-3.5-flash or newer)
# https://ai.google.dev/gemini-api/docs/api-key
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Gradium — voice-guided tours (optional)
# https://docs.gradium.ai/
GRADIUM_API_KEY=

# Local database (SQLite)
DATABASE_URL="file:.data/wayfinder.db"

# Cloudflare D1 (production on Render)
CF_ACCOUNT_ID=
CF_D1_DATABASE_ID=
CLOUDFLARE_API_TOKEN=

# NextAuth
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Render deploy script only (do not commit real values)
RENDER_API_KEY=

# Production URL (set after deploy)
# NEXT_PUBLIC_APP_URL=https://wayfinder.onrender.com
